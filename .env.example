# ============================================
# Outer Image RFP Portal — Environment Variables
# ============================================
# Copy this to .env.local and fill in real values

# Airtable
AIRTABLE_API_KEY=pat_xxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# n8n Webhook
N8N_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/rfp-intake

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=vercel_blob_xxxxxxxxxxxxxxx

# OpenAI (used in n8n, but stored here for portal-side validation)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxx

# Google Gemini (used in n8n)
GEMINI_API_KEY=AIzaXXXXXXXXXXXXXXXXX

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
